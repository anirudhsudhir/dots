font-family = "BerkeleyMono Nerd Font Mono"
font-size = 15
font-thicken = true
background-opacity = 1
window-width = 1000
window-height = 1000

keybind = ctrl+w>shift+'=new_split:right
keybind = ctrl+w>'=new_split:down
keybind = ctrl+w>n=new_tab
keybind = global:ctrl+q=toggle_quick_terminal
theme = tokyonight

