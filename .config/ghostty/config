font-family = JuliaMono Nerd Font
font-thicken = true
font-size = 14
# font-style = bold
# font-style = medium

background-opacity = 1
# macos-titlebar-style=hidden
window-padding-x=10
window-padding-y=10

# theme = light:Rose Pine Dawn, dark: Rose Pine Moon
theme = light:Catppuccin Latte, dark: Rose Pine Moon
# theme = light:Builtin Solarized Light, dark: Tokyonight Night
# theme = Tokyonight Night
macos-icon = xray

# custom-shader = ~/.config/ghostty/shaders/retro-terminal.glsl

keybind = global:ctrl+q=toggle_quick_terminal
keybind = ctrl+"=new_split:right
keybind = ctrl+%=new_split:down
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right
